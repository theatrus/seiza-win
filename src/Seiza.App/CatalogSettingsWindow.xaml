<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Seiza.App.CatalogSettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Seiza.App"
    xmlns:models="using:Seiza.App.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Catalog Settings — Seiza"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="ContentRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="SettingsTitleBar" Title="Catalog Settings">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <Grid
                MaxWidth="900"
                Padding="32,24,32,40"
                HorizontalAlignment="Stretch"
                RowSpacing="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="6">
                    <TextBlock
                        Style="{StaticResource TitleTextBlockStyle}"
                        Text="Catalog data" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Install and verify the local star, solving, and overlay catalogs used by Seiza."
                        TextWrapping="Wrap" />
                </StackPanel>

                <InfoBar
                    x:Name="ErrorInfoBar"
                    Grid.Row="1"
                    IsClosable="True"
                    IsOpen="False"
                    Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                    Severity="Error"
                    Title="Catalog setup needs attention" />

                <StackPanel Grid.Row="2" Spacing="12">
                    <TextBlock
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Text="Location" />
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.DirectoryModeText, Mode=OneWay}" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind ViewModel.DirectoryText, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap" />
                            </StackPanel>
                            <StackPanel
                                Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8">
                                <Button
                                    x:Name="UseDefaultButton"
                                    Click="UseDefault_Click"
                                    Content="Use default"
                                    IsEnabled="{x:Bind ViewModel.CanChangeDirectory, Mode=OneWay}" />
                                <Button
                                    Click="ChooseFolder_Click"
                                    Content="Choose folder…"
                                    IsEnabled="{x:Bind ViewModel.CanChangeDirectory, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="3" Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="Status" />
                        <Button
                            x:Name="RefreshButton"
                            Grid.Column="1"
                            Click="Refresh_Click"
                            IsEnabled="{x:Bind ViewModel.CanRefresh, Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ProgressRing
                                    Width="16"
                                    Height="16"
                                    IsActive="{x:Bind ViewModel.IsRefreshing, Mode=OneWay}" />
                                <TextBlock Text="Refresh" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="{x:Bind ViewModel.SolvingGlyph, Mode=OneWay}" />
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Plate solving" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind ViewModel.SolvingState, Mode=OneWay}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border
                            Grid.Column="1"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="{x:Bind ViewModel.OverlayGlyph, Mode=OneWay}" />
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Sky overlays" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind ViewModel.OverlayState, Mode=OneWay}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel>
                            <Grid MinHeight="58" Padding="16,10" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="{x:Bind ViewModel.StarCatalogGlyph, Mode=OneWay}" />
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Text="Star catalog" />
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.StarCatalogPath, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{x:Bind ViewModel.StarCatalogState, Mode=OneWay}" />
                            </Grid>
                            <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" />
                            <Grid MinHeight="58" Padding="16,10" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="{x:Bind ViewModel.BlindIndexGlyph, Mode=OneWay}" />
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Text="Blind index" />
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.BlindIndexPath, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{x:Bind ViewModel.BlindIndexState, Mode=OneWay}" />
                            </Grid>
                            <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" />
                            <Grid MinHeight="58" Padding="16,10" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="{x:Bind ViewModel.ObjectsGlyph, Mode=OneWay}" />
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Text="Deep-sky objects" />
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.ObjectsPath, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{x:Bind ViewModel.ObjectsState, Mode=OneWay}" />
                            </Grid>
                            <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" />
                            <Grid MinHeight="58" Padding="16,10" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="{x:Bind ViewModel.TransientsGlyph, Mode=OneWay}" />
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Text="Transients" />
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.TransientsPath, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{x:Bind ViewModel.TransientsState, Mode=OneWay}" />
                            </Grid>
                            <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" />
                            <Grid MinHeight="58" Padding="16,10" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="{x:Bind ViewModel.MinorBodiesGlyph, Mode=OneWay}" />
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Text="Minor bodies" />
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.MinorBodiesPath, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{x:Bind ViewModel.MinorBodiesState, Mode=OneWay}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="4" Spacing="12">
                    <TextBlock
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Text="Install or repair" />
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="14">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox
                                    MinWidth="340"
                                    Header="Catalog preset"
                                    ItemsSource="{x:Bind ViewModel.Presets}"
                                    SelectedItem="{x:Bind ViewModel.SelectedPreset, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:CatalogPresetOption">
                                            <StackPanel MaxWidth="420" Padding="0,4" Spacing="2">
                                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="{x:Bind Description}"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button
                                    Grid.Column="1"
                                    VerticalAlignment="Bottom"
                                    Click="Install_Click"
                                    Content="{x:Bind ViewModel.SetupButtonText, Mode=OneWay}"
                                    IsEnabled="{x:Bind ViewModel.CanStartSetup, Mode=OneWay}"
                                    Style="{StaticResource AccentButtonStyle}" />
                            </Grid>

                            <StackPanel x:Name="ProgressPanel" Spacing="8">
                                <ProgressBar
                                    IsIndeterminate="{x:Bind ViewModel.IsProgressIndeterminate, Mode=OneWay}"
                                    Maximum="100"
                                    Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}" />
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SetupMessage, Mode=OneWay}" TextWrapping="Wrap" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind ViewModel.SetupDetail, Mode=OneWay}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Text="Verification reads every selected file completely and checks its SHA-256 digest before installation. Large catalogs may take several minutes."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
