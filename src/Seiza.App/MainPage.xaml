<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Seiza.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Seiza.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <CommandBar
            x:Name="Toolbar"
            DefaultLabelPosition="Right"
            IsDynamicOverflowEnabled="True">
            <AppBarButton
                Click="OpenImage_Click"
                Label="Open image"
                ToolTipService.ToolTip="Open image (Ctrl+O)">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8E5;" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="O" Modifiers="Control" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarButton
                Click="OpenFolder_Click"
                Label="Open folder"
                ToolTipService.ToolTip="Open folder (Ctrl+Shift+O)">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8B7;" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="O" Modifiers="Control,Shift" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>

            <AppBarSeparator />

            <AppBarButton
                Click="Previous_Click"
                IsEnabled="{x:Bind ViewModel.CanNavigatePrevious, Mode=OneWay}"
                Label="Previous"
                ToolTipService.ToolTip="Previous image (Left arrow)">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE72B;" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Left" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarButton
                Click="Next_Click"
                IsEnabled="{x:Bind ViewModel.CanNavigateNext, Mode=OneWay}"
                Label="Next"
                ToolTipService.ToolTip="Next image (Right arrow)">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE72A;" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Right" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>

            <AppBarSeparator />

            <AppBarButton
                Click="Fit_Click"
                IsEnabled="{x:Bind ViewModel.HasImage, Mode=OneWay}"
                Label="Fit"
                ToolTipService.ToolTip="Fit image to window (F)">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE799;" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="F" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarButton
                Click="ZoomOut_Click"
                IsEnabled="{x:Bind ViewModel.HasImage, Mode=OneWay}"
                Label="Zoom out"
                ToolTipService.ToolTip="Zoom out">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE71F;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton
                Click="ZoomIn_Click"
                IsEnabled="{x:Bind ViewModel.HasImage, Mode=OneWay}"
                Label="Zoom in"
                ToolTipService.ToolTip="Zoom in">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8A3;" />
                </AppBarButton.Icon>
            </AppBarButton>

            <AppBarSeparator />

            <AppBarButton
                x:Name="UndoStretchButton"
                Click="UndoStretch_Click"
                IsEnabled="False"
                Label="Undo stretch"
                ToolTipService.ToolTip="Undo the last stretch change (Ctrl+Z)">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE7A7;" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Z" Modifiers="Control" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarButton
                x:Name="RedoStretchButton"
                Click="RedoStretch_Click"
                IsEnabled="False"
                Label="Redo stretch"
                ToolTipService.ToolTip="Redo the last stretch change (Ctrl+Shift+Z)">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE7A6;" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Z" Modifiers="Control,Shift" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarButton
                x:Name="StretchButton"
                Click="Stretch_Click"
                IsEnabled="False"
                Label="Stretch"
                ToolTipService.ToolTip="Stretch controls are available for FITS images">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE790;" />
                </AppBarButton.Icon>
            </AppBarButton>

            <AppBarButton
                x:Name="SolveButton"
                Click="Solve_Click"
                IsEnabled="False"
                Label="Solve"
                ToolTipService.ToolTip="Plate solve the current image">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE9D9;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton
                x:Name="OverlayButton"
                IsEnabled="False"
                Label="Overlays"
                ToolTipService.ToolTip="Choose visible plate-solve overlays">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE81E;" />
                </AppBarButton.Icon>
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <ToggleMenuFlyoutItem x:Name="DeepSkyOverlayItem" Click="OverlayToggle_Click" IsChecked="True" Text="Deep-sky objects" />
                        <ToggleMenuFlyoutItem x:Name="NamedStarsOverlayItem" Click="OverlayToggle_Click" IsChecked="True" Text="Named stars" />
                        <ToggleMenuFlyoutItem x:Name="TransientsOverlayItem" Click="OverlayToggle_Click" IsChecked="True" Text="Current transients" />
                        <ToggleMenuFlyoutItem x:Name="HistoricalTransientsOverlayItem" Click="OverlayToggle_Click" Text="Historical transients" />
                        <ToggleMenuFlyoutItem x:Name="MinorBodiesOverlayItem" Click="OverlayToggle_Click" IsChecked="True" Text="Solar-system bodies" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutSubItem Text="Deep-sky catalogs">
                            <ToggleMenuFlyoutItem x:Name="MessierCatalogItem" Click="CatalogToggle_Click" IsChecked="True" Text="Messier" />
                            <ToggleMenuFlyoutItem x:Name="NgcCatalogItem" Click="CatalogToggle_Click" IsChecked="True" Text="NGC" />
                            <ToggleMenuFlyoutItem x:Name="IcCatalogItem" Click="CatalogToggle_Click" IsChecked="True" Text="IC" />
                            <ToggleMenuFlyoutItem x:Name="SharplessVdbCatalogItem" Click="CatalogToggle_Click" IsChecked="True" Text="Sharpless / vdB" />
                            <ToggleMenuFlyoutItem x:Name="LbnCatalogItem" Click="CatalogToggle_Click" IsChecked="True" Text="LBN" />
                            <ToggleMenuFlyoutItem x:Name="CederbladCatalogItem" Click="CatalogToggle_Click" IsChecked="True" Text="Cederblad" />
                            <ToggleMenuFlyoutItem x:Name="DarkNebulaeCatalogItem" Click="CatalogToggle_Click" IsChecked="True" Text="Dark nebulae" />
                            <ToggleMenuFlyoutItem x:Name="SupernovaRemnantsCatalogItem" Click="CatalogToggle_Click" IsChecked="True" Text="Supernova remnants" />
                            <ToggleMenuFlyoutItem x:Name="UgcCatalogItem" Click="CatalogToggle_Click" IsChecked="True" Text="UGC" />
                            <ToggleMenuFlyoutItem x:Name="PgcCatalogItem" Click="CatalogToggle_Click" IsChecked="True" Text="PGC" />
                            <ToggleMenuFlyoutItem x:Name="OtherCatalogItem" Click="CatalogToggle_Click" IsChecked="True" Text="Other catalogs" />
                        </MenuFlyoutSubItem>
                        <MenuFlyoutSeparator />
                        <ToggleMenuFlyoutItem x:Name="CatalogOutlinesOverlayItem" Click="OverlayToggle_Click" IsChecked="True" Text="Detailed catalog outlines" />
                        <ToggleMenuFlyoutItem x:Name="ObjectLabelsOverlayItem" Click="OverlayToggle_Click" IsChecked="True" Text="Object labels" />
                        <ToggleMenuFlyoutItem x:Name="FieldStarsOverlayItem" Click="OverlayToggle_Click" Text="Field stars" />
                        <ToggleMenuFlyoutItem x:Name="CoordinateGridOverlayItem" Click="OverlayToggle_Click" IsChecked="True" Text="RA / Dec grid" />
                        <ToggleMenuFlyoutItem x:Name="FieldCenterOverlayItem" Click="OverlayToggle_Click" IsChecked="True" Text="Field center" />
                        <ToggleMenuFlyoutItem x:Name="DetectedStarsOverlayItem" Click="OverlayToggle_Click" Text="Detected stars" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Click="HideAllOverlays_Click" Text="Hide all overlays" />
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>
            <AppBarButton
                x:Name="ExportButton"
                IsEnabled="False"
                Label="Export"
                ToolTipService.ToolTip="Export the stretched image">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xEDE1;" />
                </AppBarButton.Icon>
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Name="ExportImageItem" Click="ExportImage_Click" Text="Export image..." />
                        <MenuFlyoutItem x:Name="ExportOverlaysItem" Click="ExportOverlays_Click" IsEnabled="False" Text="Export with visible overlays..." />
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>

            <AppBarSeparator />

            <AppBarButton
                x:Name="InspectorButton"
                Click="Inspector_Click"
                IsEnabled="{x:Bind ViewModel.HasImage, Mode=OneWay}"
                Label="Inspector"
                ToolTipService.ToolTip="Show image details, FITS headers, and plate-solve information">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE700;" />
                </AppBarButton.Icon>
            </AppBarButton>

            <AppBarSeparator />

            <AppBarButton
                Click="CatalogSettings_Click"
                Label="Catalogs"
                ToolTipService.ToolTip="Catalog settings">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE713;" />
                </AppBarButton.Icon>
            </AppBarButton>

            <AppBarSeparator />

            <AppBarButton
                Click="About_Click"
                Label="About"
                ToolTipService.ToolTip="About Seiza">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE946;" />
                </AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <SplitView
            x:Name="WorkspaceSplitView"
            Grid.Row="1"
            DisplayMode="Inline"
            IsPaneOpen="False"
            OpenPaneLength="380"
            PanePlacement="Right">
            <SplitView.Pane>
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Padding="16,12,8,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                Style="{StaticResource TitleTextBlockStyle}"
                                Text="Inspector" />
                            <Button
                                Grid.Column="1"
                                AutomationProperties.Name="Close inspector"
                                Click="CloseInspector_Click"
                                Style="{StaticResource SubtleButtonStyle}"
                                ToolTipService.ToolTip="Close inspector">
                                <FontIcon Glyph="&#xE711;" />
                            </Button>
                        </Grid>
                        <local:ImageInspector x:Name="InspectorControl" Grid.Row="1" />
                    </Grid>
                </Border>
            </SplitView.Pane>
            <SplitView.Content>
        <Grid
            AllowDrop="True"
            Background="#FF080A0F"
            DragOver="Viewport_DragOver"
            Drop="Viewport_Drop">
            <canvas:CanvasControl
                x:Name="ImageCanvas"
                ClearColor="#FF080A0F"
                Draw="ImageCanvas_Draw"
                PointerCaptureLost="ImageCanvas_PointerCaptureLost"
                PointerMoved="ImageCanvas_PointerMoved"
                PointerPressed="ImageCanvas_PointerPressed"
                PointerReleased="ImageCanvas_PointerReleased"
                PointerWheelChanged="ImageCanvas_PointerWheelChanged"
                SizeChanged="ImageCanvas_SizeChanged" />

            <StackPanel
                x:Name="WelcomePanel"
                MaxWidth="560"
                Padding="48"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="14">
                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="Seiza" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="Fast native astronomy image viewing for Windows"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="Open a FITS or standard image, choose a folder, or drop one here."
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="{x:Bind ViewModel.CoreVersionText, Mode=OneWay}" />
            </StackPanel>

            <Border
                x:Name="LoadingPanel"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                CornerRadius="12"
                Visibility="Collapsed">
                <StackPanel Spacing="12">
                    <ProgressRing
                        Width="36"
                        Height="36"
                        HorizontalAlignment="Center"
                        IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <StackPanel
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Spacing="8">
            <InfoBar
                x:Name="ErrorInfoBar"
                Margin="16"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                IsClosable="True"
                IsOpen="False"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                Severity="Error"
                Title="Couldn’t open image" />
                <InfoBar
                    x:Name="SolveErrorInfoBar"
                    Margin="16,0,16,0"
                    IsClosable="True"
                    IsOpen="False"
                    Message="{x:Bind ViewModel.SolveErrorMessage, Mode=OneWay}"
                    Severity="Error"
                    Title="Plate solve failed">
                    <InfoBar.ActionButton>
                        <Button
                            x:Name="SolveCatalogSettingsButton"
                            Click="CatalogSettings_Click"
                            Content="Open Catalog Settings"
                            Visibility="Collapsed" />
                    </InfoBar.ActionButton>
                </InfoBar>
            </StackPanel>

            <Border
                x:Name="SolveSummaryCard"
                MinWidth="310"
                MaxWidth="480"
                Margin="16"
                Padding="14,11"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Background="#D9181C25"
                BorderBrush="#5AFFFFFF"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="Collapsed">
                <StackPanel Spacing="3">
                    <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SolveTitleText, Mode=OneWay}" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.SolveCoordinatesText, Mode=OneWay}" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.SolveQualityText, Mode=OneWay}" />
                    <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind ViewModel.SolveOverlayText, Mode=OneWay}" TextWrapping="Wrap" />
                    <TextBlock Foreground="#FFF2C66D" Text="{x:Bind ViewModel.SolveAvailabilityText, Mode=OneWay}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
            </SplitView.Content>
        </SplitView>

        <Grid
            Grid.Row="2"
            MinHeight="32"
            Padding="12,4"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                MaxWidth="320"
                VerticalAlignment="Center"
                FontWeight="SemiBold"
                Text="{x:Bind ViewModel.FileName, Mode=OneWay}"
                TextTrimming="CharacterEllipsis" />
            <TextBlock
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                TextTrimming="CharacterEllipsis" />
            <TextBlock
                Grid.Column="2"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind ViewModel.PositionText, Mode=OneWay}" />
        </Grid>
    </Grid>
</Page>
