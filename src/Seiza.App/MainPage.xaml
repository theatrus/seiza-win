<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Seiza.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <CommandBar
            x:Name="Toolbar"
            DefaultLabelPosition="Right"
            IsDynamicOverflowEnabled="True">
            <AppBarButton
                Click="OpenImage_Click"
                Label="Open image"
                ToolTipService.ToolTip="Open image (Ctrl+O)">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8E5;" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="O" Modifiers="Control" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarButton
                Click="OpenFolder_Click"
                Label="Open folder"
                ToolTipService.ToolTip="Open folder (Ctrl+Shift+O)">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8B7;" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="O" Modifiers="Control,Shift" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>

            <AppBarSeparator />

            <AppBarButton
                Click="Previous_Click"
                IsEnabled="{x:Bind ViewModel.CanNavigatePrevious, Mode=OneWay}"
                Label="Previous"
                ToolTipService.ToolTip="Previous image (Left arrow)">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE72B;" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Left" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarButton
                Click="Next_Click"
                IsEnabled="{x:Bind ViewModel.CanNavigateNext, Mode=OneWay}"
                Label="Next"
                ToolTipService.ToolTip="Next image (Right arrow)">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE72A;" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Right" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>

            <AppBarSeparator />

            <AppBarButton
                Click="Fit_Click"
                IsEnabled="{x:Bind ViewModel.HasImage, Mode=OneWay}"
                Label="Fit"
                ToolTipService.ToolTip="Fit image to window (F)">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE799;" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="F" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarButton
                Click="ZoomOut_Click"
                IsEnabled="{x:Bind ViewModel.HasImage, Mode=OneWay}"
                Label="Zoom out"
                ToolTipService.ToolTip="Zoom out">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE71F;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton
                Click="ZoomIn_Click"
                IsEnabled="{x:Bind ViewModel.HasImage, Mode=OneWay}"
                Label="Zoom in"
                ToolTipService.ToolTip="Zoom in">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8A3;" />
                </AppBarButton.Icon>
            </AppBarButton>

            <AppBarSeparator />

            <AppBarButton
                Click="CatalogSettings_Click"
                Label="Catalogs"
                ToolTipService.ToolTip="Catalog settings">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE713;" />
                </AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <Grid
            Grid.Row="1"
            AllowDrop="True"
            Background="#FF080A0F"
            DragOver="Viewport_DragOver"
            Drop="Viewport_Drop">
            <canvas:CanvasControl
                x:Name="ImageCanvas"
                ClearColor="#FF080A0F"
                Draw="ImageCanvas_Draw"
                PointerCaptureLost="ImageCanvas_PointerCaptureLost"
                PointerMoved="ImageCanvas_PointerMoved"
                PointerPressed="ImageCanvas_PointerPressed"
                PointerReleased="ImageCanvas_PointerReleased"
                PointerWheelChanged="ImageCanvas_PointerWheelChanged"
                SizeChanged="ImageCanvas_SizeChanged" />

            <StackPanel
                x:Name="WelcomePanel"
                MaxWidth="560"
                Padding="48"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="14">
                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="Seiza" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="Fast native astronomy image viewing for Windows"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="Open a FITS or standard image, choose a folder, or drop one here."
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="{x:Bind ViewModel.CoreVersionText, Mode=OneWay}" />
            </StackPanel>

            <Border
                x:Name="LoadingPanel"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                CornerRadius="12"
                Visibility="Collapsed">
                <StackPanel Spacing="12">
                    <ProgressRing
                        Width="36"
                        Height="36"
                        HorizontalAlignment="Center"
                        IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <InfoBar
                x:Name="ErrorInfoBar"
                Margin="16"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                IsClosable="True"
                IsOpen="False"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                Severity="Error"
                Title="Couldn’t open image" />
        </Grid>

        <Grid
            Grid.Row="2"
            MinHeight="32"
            Padding="12,4"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                MaxWidth="320"
                VerticalAlignment="Center"
                FontWeight="SemiBold"
                Text="{x:Bind ViewModel.FileName, Mode=OneWay}"
                TextTrimming="CharacterEllipsis" />
            <TextBlock
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                TextTrimming="CharacterEllipsis" />
            <TextBlock
                Grid.Column="2"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind ViewModel.PositionText, Mode=OneWay}" />
        </Grid>
    </Grid>
</Page>
